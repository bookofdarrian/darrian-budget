# sole_alert_bot/.env.example
# Copy this to .env and fill in your values.
# On CT100, set these as real environment variables (not a .env file)
# so they're available to the cron job.
#
# To set on CT100:
#   echo 'export DATABASE_URL="postgres://..."' >> /etc/environment
#   (then reboot or: source /etc/environment)

# ── Required ──────────────────────────────────────────────────────────────────

# Your Railway Postgres connection string
# Find it: Railway dashboard → darrian-budget → Variables → DATABASE_URL
DATABASE_URL=postgres://user:password@host:5432/dbname

# Telegram bot token — from @BotFather on Telegram
# Steps: message @BotFather → /newbot → follow prompts → copy token
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ

# Your Telegram chat ID — how to find it:
# 1. Message your new bot once (any text)
# 2. Open: https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
# 3. Look for "chat":{"id": 123456789} — that number is your chat ID
TELEGRAM_CHAT_ID=123456789

# eBay API credentials — already saved in your budget app Postgres settings table
# Find them: budget app → Business Tracker → eBay API Credentials section
# Or: Railway dashboard → darrian-budget → Variables
EBAY_CLIENT_ID=DarrianB-404Sole-PRD-xxxxxxxxxxxx-xxxxxxxx
EBAY_CLIENT_SECRET=PRD-xxxxxxxxxxxxxxxxxxxx-xxxxxxxx-xxxx-xxxx

# ── Optional tuning ───────────────────────────────────────────────────────────

# Minimum net profit (after fees) to trigger an alert. Default: $30
MIN_PROFIT_THRESHOLD=30

# eBay fee rate (decimal). Default: 12.9% = 0.129
EBAY_FEE_RATE=0.129

# eBay fixed fee per transaction. Default: $0.30
EBAY_FEE_FIXED=0.30

# Mercari fee rate (decimal). Default: 10% = 0.10
MERCARI_FEE_RATE=0.10

# Mercari fixed fee per transaction. Default: $0.30
MERCARI_FEE_FIXED=0.30
