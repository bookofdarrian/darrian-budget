{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(python3 -m py_compile *)",
      "Bash(pytest *)",
      "Bash(echo *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(grep *)",
      "Read(**)",
      "Write(**)"
    ],
    "ask": [
      "Bash(git push *)",
      "Bash(git merge *)",
      "Bash(pip install *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(curl * | bash *)"
    ]
  }
}
