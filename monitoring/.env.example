# ─────────────────────────────────────────────────────────────────────────────
# Monitoring Stack — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=homelab2026   # CHANGE THIS

# ── Pushover (iPhone push notifications) — RECOMMENDED ───────────────────────
# Sign up at https://pushover.net (free 30-day trial, then $5 one-time)
# 1. Create account → note your User Key
# 2. Create an Application → note the API Token
# 3. Install Pushover app on iPhone → sign in
PUSHOVER_USER_KEY=your_pushover_user_key_here
PUSHOVER_API_TOKEN=your_pushover_app_token_here

# ── Telegram (free alternative to Pushover) ───────────────────────────────────
# 1. Open Telegram → search @BotFather → /newbot → follow prompts → get TOKEN
# 2. Message your new bot once, then run:
#    curl https://api.telegram.org/bot<TOKEN>/getUpdates
#    Find "chat":{"id": <NUMBER>} — that's your CHAT_ID
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Email Alerts (Gmail SMTP) — optional fallback ─────────────────────────────
# For Gmail: enable 2FA → Google Account → Security → App Passwords → generate one
GF_SMTP_ENABLED=false
GF_SMTP_HOST=smtp.gmail.com:587
GF_SMTP_USER=your.email@gmail.com
GF_SMTP_PASSWORD=your_gmail_app_password_here
GF_SMTP_FROM_ADDRESS=your.email@gmail.com
ALERT_EMAIL_TO=your.email@gmail.com

# ── Alertmanager SMTP (same as above, for Alertmanager's own emails) ──────────
SMTP_HOST=smtp.gmail.com:587
SMTP_FROM=alerts@homelab.local
SMTP_USER=your.email@gmail.com
SMTP_PASSWORD=your_gmail_app_password_here
