[MASTER]
init-hook="from pylint.config import find_pylintrc; import sys; sys.path.append('.')"
load-plugins=pylint.extensions.docparams
jobs=4
unsafe-load-any-extension=no
extension-pkg-allow-list=

[MESSAGES CONTROL]
disable=
    missing-docstring,
    too-few-public-methods,
    too-many-arguments,
    invalid-name,
    broad-except,
    too-many-instance-attributes,
    too-many-locals,
    duplicate-code,
    line-too-long,

[REPORTS]
output-format=colorized
reports=yes
evaluation=10.0 - ((float(5 * error + warning + refactor + convention) / statement) * 10)

[REFACTORING]
max-nested-blocks=5

[LOGGING]
logging-format-style=new
logging-modules=logging

[FORMAT]
max-line-length=100
indent-string='    '
indent-after-paren=4
expected-line-ending-format=LF

[VARIABLES]
init-import=no
dummy-variables-rgx=_+$|dummy

[BASIC]
bad-names=foo,bar,baz,tata,tutu,titi
module-rgx=(([a-z_][a-z0-9_]*)|([A-Z][a-zA-Z0-9]+))$
const-rgx=(([A-Z_][A-Z0-9_]*)|(__.*__)|(_.*)|([a-z_][a-z0-9_]*))$
class-rgx=[A-Z_][a-zA-Z0-9]+$
function-rgx=([a-z_][a-z0-9_]*|test_[a-z0-9_]+)$
method-rgx=([a-z_][a-z0-9_]*|setUp|tearDown|setUpClass|tearDownClass|setUpModule|tearDownModule|test_[a-z0-9_]+)$
attr-rgx=[a-z_][a-z0-9_]*$
argument-rgx=[a-z_][a-z0-9_]*$
variable-rgx=[a-z_][a-z0-9_]*$
class-attribute-rgx=([A-Za-z_][A-Za-z0-9_]{2,30}|(__.*__))$

[DESIGN]
max-args=7
max-attributes=10
max-bool-expr=5
max-branches=12
max-locals=20
max-parents=7
max-public-methods=20
max-returns=6
max-statements=50
min-public-methods=2
too-many-branches-threshold=12

[EXCEPTIONS]
overgeneral-exceptions=Exception
